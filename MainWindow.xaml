<Window x:Class="EIP2042_Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EIP-2042 Controller" Height="350" Width="450" Closed="Window_Closed">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Label Content="IP Address:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox x:Name="IpTextBox" Width="120" Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
            <Button x:Name="ConnectButton" Content="Connect" Width="80" Height="25" Margin="5,0" Click="ConnectButton_Click"/>
            <Label x:Name="StatusLabel" Content="Disconnected" Foreground="Red" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Digital Output (16 Channels)" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

        <WrapPanel x:Name="ChannelsPanel" Grid.Row="2" Orientation="Horizontal">
            <!-- DO 채널 버튼들은 코드 비하인드에서 동적 생성됩니다. -->
        </WrapPanel>
    </Grid>
</Window>
